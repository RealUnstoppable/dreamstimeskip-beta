rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection: Users can only read/write their own profile
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;

      // Prevent privilege escalation by restricting sensitive fields
      allow create: if request.auth != null && request.auth.uid == userId
                    && (!request.resource.data.keys().hasAny(['isAdmin']) || request.resource.data.isAdmin == false)
                    && (!request.resource.data.keys().hasAny(['membershipLevel']) || request.resource.data.membershipLevel == 'free')
                    && (!request.resource.data.keys().hasAny(['plan']) || request.resource.data.plan == 'free')
                    && !request.resource.data.keys().hasAny(['subscription']);

      allow update: if request.auth != null && request.auth.uid == userId
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin', 'membershipLevel', 'plan', 'subscription']);

      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Carts collection: Users can only read/write their own cart
    match /carts/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Orders collection: Users can read their own orders and create new ones
    match /orders/{orderId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      // Depending on checkout implementation, orders are created by user or backend.
      // Assuming frontend creation for now based on 'userId' equality:
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // Support tickets collection
    match /support_tickets/{ticketId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true);
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

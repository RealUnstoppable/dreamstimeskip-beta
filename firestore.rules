rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      // Existing rules for users (if any, preserving logic)
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /feature_requests/{requestId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && request.auth.uid == resource.data.uid;
    }
    match /maintenance_tickets/{ticketId} {
      // Creation is only allowed via Cloud Function (admin SDK)
      allow create: if false;
      allow read, update: if request.auth != null && request.auth.uid == resource.data.uid && (!request.resource.data.keys().hasAny(['uid']) || request.resource.data.uid == request.auth.uid);
      allow delete: if request.auth != null && request.auth.uid == resource.data.uid;
    }
  }
}
